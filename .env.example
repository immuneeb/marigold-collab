# ============================================================================
# Marigold — local dev environment. Copy to .env (gitignored) and fill in.
# Most values below work out-of-the-box for local-first dev. The ones marked
# (PROVIDE) need real credentials before that feature works.
# ============================================================================

# --- Origins -----------------------------------------------------------------
# App origin (the control plane / dashboard / MCP). Google OAuth lives here.
APP_ORIGIN=http://localhost:3000
# Render origin: untrusted docs are served from d-<rand> under this base.
# Dev uses *.usercontent.localhost (resolves to 127.0.0.1, real distinct origin).
# Prod: marigoldusercontent.com (a SEPARATE registrable domain — claude.ai model).
RENDER_BASE_HOST=usercontent.localhost:8787
RENDER_BASE_SCHEME=http

# --- Auth (Auth.js v5) -------------------------------------------------------
# openssl rand -base64 32
AUTH_SECRET=dev-only-change-me-0000000000000000000000000=
AUTH_URL=http://localhost:3000
# Dev login: when DEV_AUTH=1 AND not production, a passwordless email login is
# enabled so you can test without Google. NEVER set in production.
DEV_AUTH=1
# (PROVIDE) Google OAuth client — https://console.cloud.google.com
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Database ----------------------------------------------------------------
# Local dev: a real Postgres (see README setup: brew install postgresql@16,
# then `createdb marigold`). Prod: set DATABASE_URL to your Neon connection
# string. The default below connects as your OS user with no password.
DATABASE_URL=postgres://127.0.0.1:5432/marigold

# --- Render token (EdDSA: app signs, Worker only verifies) --------------------
# Generate a local keypair: pnpm --filter @marigold/core keygen
# Private key (PKCS8 PEM, app only). Public key (SPKI PEM, Worker + app).
RENDER_TOKEN_KID=k1
RENDER_TOKEN_PRIVATE_KEY=
RENDER_TOKEN_PUBLIC_KEY=
# Capability token lifetime in seconds (<=60, bounds revocation lag).
RENDER_TOKEN_TTL=60

# --- Blob storage ------------------------------------------------------------
# Local-first: fs (app + render worker share one local dir). Prod: r2.
BLOB_DRIVER=fs
BLOB_FS_DIR=.blobs
# (PROVIDE for prod) Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=marigold-blobs
R2_ENDPOINT=

# --- Email (Phase 3 invites) -------------------------------------------------
# Without a key, invite links are logged to the console (dev fallback).
RESEND_API_KEY=
EMAIL_FROM=Marigold <invites@marigold.app>

# --- Limits ------------------------------------------------------------------
MAX_DOC_BYTES=2000000
MAX_DOC_FILES=50
