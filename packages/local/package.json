{
  "name": "marigold-draft",
  "version": "0.1.0",
  "description": "Local Marigold review loop for agent-authored HTML/SVG drafts — comment in the browser, feedback flows straight back to your coding agent.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/immuneeb/marigold-collab.git",
    "directory": "packages/local"
  },
  "homepage": "https://marigold-collab-web.vercel.app/draft/setup.md",
  "keywords": ["marigold", "review", "comments", "agent", "mcp", "html", "draft"],
  "type": "module",
  "bin": {
    "marigold-draft": "./dist/cli.cjs",
    "marigold-local": "./dist/cli.cjs"
  },
  "files": ["dist/cli.cjs", "README.md"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node build.mjs",
    "prepublishOnly": "node build.mjs",
    "dev": "tsx src/cli.ts serve",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@marigold/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@types/node": "^22.10.5",
    "esbuild": "^0.25.0",
    "node-html-parser": "^7.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "zod": "^3.24.1"
  }
}
